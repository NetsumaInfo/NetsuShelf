{
  "manifest_version": 3,
  "name": "NetsuShelf",
  "description": "Convert supported web novels and story pages into EPUB files for offline reading.",
  "version": "1.0.12.8",
  "default_locale": "en",
  "icons": {
    "128": "book128.png"
  },
  "permissions": [
    "cookies",
    "downloads",
    "webRequest",
    "declarativeNetRequest",
    "scripting",
    "storage",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "browser_style": false,
    "default_title": "NetsuShelf",
    "default_icon": "book128.png",
    "default_popup": "popup.html"
  },
  "incognito": "split",
  "browser_specific_settings": {
    "gecko": {
      "id": "netsushelf@netsuma.info",
      "data_collection_permissions": {
        "required": [
          "none"
        ],
        "optional": []
      },
      "strict_min_version": "142.0"
    }
  },
  "minimum_chrome_version": "120"
}
